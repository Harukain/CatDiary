# 猫伴日记 Production 环境模板
# 复制为 ../.env.production 后，通过密钥管理或受控终端替换所有 __...__ 占位值。
# 不要把真实 .env.production 提交到 Git。

NODE_ENV=production
APP_ENV=production
PORT=3000

DATABASE_URL=__PRODUCTION_POSTGRESQL_URL__
REDIS_URL=__PRODUCTION_REDIS_OR_REDISS_URL__

JWT_ACCESS_SECRET=__PRODUCTION_JWT_ACCESS_SECRET_32_PLUS__
JWT_REFRESH_SECRET=__PRODUCTION_JWT_REFRESH_SECRET_32_PLUS__
PHONE_LOOKUP_SECRET=__PRODUCTION_PHONE_LOOKUP_SECRET_32_PLUS__
PHONE_ENCRYPTION_SECRET=__PRODUCTION_PHONE_ENCRYPTION_SECRET_32_PLUS__
CHANNEL_ENCRYPTION_SECRET=__PRODUCTION_CHANNEL_ENCRYPTION_SECRET_32_PLUS__
DEV_OTP_CODE=__PRODUCTION_NON_123456_SIX_DIGITS__
DEFAULT_TIMEZONE=Asia/Shanghai

PUBLIC_API_URL=https://api.your-domain.example/api/v1
EXPO_PUBLIC_API_URL=https://api.your-domain.example/api/v1
EAS_PROJECT_ID=29f29ec5-c4ab-4371-bf41-b5b72077e531
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://your-domain.example/privacy
EXPO_PUBLIC_TERMS_URL=https://your-domain.example/terms

CORS_ALLOWED_ORIGINS=https://app.your-domain.example
TRUST_PROXY=true
ENABLE_SWAGGER=false
FEATURE_NOTIFICATIONS_ENABLED=true
FEATURE_EXPORTS_ENABLED=true
METRICS_TOKEN=__PRODUCTION_METRICS_TOKEN_32_PLUS__
WORKER_HOST=0.0.0.0
WORKER_PORT=3001
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_SMS_SEND_LIMIT=5
THROTTLE_SMS_VERIFY_LIMIT=10

COS_SECRET_ID=__PRODUCTION_COS_SECRET_ID__
COS_SECRET_KEY=__PRODUCTION_COS_SECRET_KEY__
COS_BUCKET=__PRODUCTION_COS_PRIVATE_BUCKET__
COS_REGION=ap-shanghai

SMS_APP_ID=__PRODUCTION_SMS_APP_ID__
SMS_SIGN_NAME=__PRODUCTION_SMS_SIGN_NAME__
SMS_TEMPLATE_ID=__PRODUCTION_SMS_TEMPLATE_ID__
SMS_SECRET_ID=__PRODUCTION_SMS_SECRET_ID__
SMS_SECRET_KEY=__PRODUCTION_SMS_SECRET_KEY__
SMS_REGION=ap-guangzhou
SMS_CODE_TTL_SECONDS=300
