{
  "name": "cat-diary",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "lint:eslint": "eslint . --max-warnings=0",
    "test": "turbo run test",
    "test:integration": "node scripts/run-integration.mjs",
    "test:restore": "./scripts/verify-backup-restore.sh",
    "test:monitoring": "./scripts/verify-monitoring.sh",
    "test:mobile-config": "node scripts/verify-mobile-config.mjs",
    "test:e2e-flows": "node scripts/verify-maestro-flows.mjs",
    "test:device-evidence": "node scripts/verify-device-evidence-gate.mjs",
    "test:acceptance-report": "node scripts/verify-acceptance-report.mjs",
    "test:preview-probe": "node scripts/verify-preview-probe.mjs",
    "test:release-image-refs": "node scripts/verify-release-image-refs.mjs",
    "test:release-plan": "node scripts/verify-release-plan.mjs",
    "test:release-preflight": "node scripts/verify-release-preflight.mjs",
    "test:release-env": "node scripts/verify-release-env-templates.mjs",
    "test:preview-compose": "node scripts/verify-preview-compose.mjs",
    "test:production-env": "node scripts/verify-production-environment.mjs",
    "test:privacy-manifest": "./scripts/verify-ios-privacy-manifest.sh",
    "eas:check": "node scripts/check-eas-readiness.mjs",
    "eas": "pnpm --dir apps/mobile eas",
    "ios:preflight": "node scripts/ios-dev-preflight.mjs",
    "android:preflight": "node scripts/android-dev-preflight.mjs",
    "acceptance:audit": "node scripts/verify-external-acceptance.mjs",
    "acceptance:gate": "node scripts/verify-external-acceptance.mjs --strict",
    "acceptance:evidence": "node scripts/verify-device-acceptance-evidence.mjs",
    "acceptance:evidence-template": "node scripts/verify-device-acceptance-evidence.mjs --file docs/DEVICE_ACCEPTANCE_EVIDENCE.example.json --allow-template",
    "acceptance:report": "node scripts/acceptance-report.mjs",
    "preview:probe": "node scripts/probe-preview-environment.mjs",
    "release:image-refs": "node scripts/release-image-refs.mjs",
    "release:plan": "node scripts/release-plan.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "e2e:maestro": "maestro test .maestro",
    "e2e:maestro:feishu-logs": "maestro test .maestro/09-feishu-settings-notification-logs.yaml",
    "e2e:maestro:android-offline": "maestro test .maestro-android/08-offline-record-sync.yaml",
    "queue:ops": "pnpm --filter @cat-diary/domain build && pnpm --filter @cat-diary/worker build && pnpm --filter @cat-diary/worker queue:ops",
    "openapi:check": "node scripts/verify-openapi.mjs",
    "openapi:update": "UPDATE_OPENAPI=1 node scripts/verify-openapi.mjs",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx,json}\" \"packages/**/*.{ts,tsx,json}\" \"scripts/**/*.mjs\" \"docs/**/*.{md,json}\" \"*.{json,md,yml}\" \".github/**/*.yml\" \".maestro/**/*.{yaml,yml}\" \".maestro-android/**/*.{yaml,yml}\"",
    "verify": "pnpm format:check && pnpm lint:eslint && pnpm test:e2e-flows && pnpm acceptance:evidence-template && pnpm test:device-evidence && pnpm test:acceptance-report && pnpm test:preview-probe && pnpm test:release-image-refs && pnpm test:release-plan && pnpm test:release-preflight && pnpm test:release-env && pnpm test:preview-compose && pnpm db:validate && pnpm typecheck && pnpm test && pnpm build && pnpm test:production-env",
    "db:generate": "prisma generate",
    "db:validate": "DATABASE_URL=postgresql://catdiary:catdiary@localhost:5433/catdiary?schema=public prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.6.2",
    "prisma": "^6.19.0",
    "turbo": "^2.5.8",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
